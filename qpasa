-- Improved Visibility Check
local function IsVisible(target)
    if not target or not target.Parent then return false end
    local character = target.Parent
    local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head")
    if not root then return false end
    
    local ray = Ray.new(Camera.CFrame.Position, (root.Position - Camera.CFrame.Position).Unit * 3000)
    local ignoreList = {LocalPlayer.Character, Workspace.CurrentCamera, Workspace.Terrain}
    local hit, _ = Workspace:FindPartOnRayWithIgnoreList(ray, ignoreList)
    
    return hit == nil or hit:IsDescendantOf(character)
end

-- Silent Aim Helper
local function GetClosestTarget()
    local closest, dist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head and IsVisible(head) then
                local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if d < dist then
                        dist = d
                        closest = head
                    end
                end
            end
        end
    end
    return closest
end

-- Aim Assist
RunService.RenderStepped:Connect(function()
    if not AimAssistEnabled then return end
    local target = GetClosestTarget()
    if target then
        local cf = Camera.CFrame
        Camera.CFrame = cf:Lerp(CFrame.lookAt(cf.Position, target.Position), AimPower/110)
    end
end)

-- ESP
RunService.RenderStepped:Connect(function()
    if not ESPEnabled then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and not plr.Character:FindFirstChild("HighlightESP") then
            local hl = Instance.new("Highlight")
            hl.Name = "HighlightESP"
            hl.FillTransparency = 0.5
            hl.OutlineColor = Color3.fromRGB(255, 60, 60)
            hl.OutlineTransparency = 0
            hl.FillColor = Color3.fromRGB(0, 255, 200)
            hl.Parent = plr.Character
        end
    end
end)

-- Stronger 100x100 Hitboxes
local rainbowHue = 0
