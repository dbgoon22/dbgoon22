-- IsVisible y GetClosestTarget
local function IsVisible(target)
    if not target or not target.Parent then return false end
    local character = target.Parent
    local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head")
    if not root then return false end
    local ray = Ray.new(Camera.CFrame.Position, (root.Position - Camera.CFrame.Position).Unit * 5000)
    local ignoreList = {LocalPlayer.Character, Workspace.CurrentCamera, Workspace.Terrain}
    local hit = Workspace:FindPartOnRayWithIgnoreList(ray, ignoreList)
    return hit == nil or hit:IsDescendantOf(character)
end

local function GetClosestTarget()
    local closest, dist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local root = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character:FindFirstChild("Head")
            if root and IsVisible(root) then
                local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if d < dist then
                        dist = d
                        closest = root
                    end
                end
            end
        end
    end
    return closest
end

-- AimAssist
RunService.RenderStepped:Connect(function()
    if not AimAssistEnabled or not HitboxEnabled then return end
    local target = GetClosestTarget()
    if target then
        local cf = Camera.CFrame
        Camera.CFrame = cf:Lerp(CFrame.lookAt(cf.Position, target.Position), AimPower/105)
    end
end)

-- ESP Negro
RunService.RenderStepped:Connect(function()
    if not ESPEnabled then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and not plr.Character:FindFirstChild("HighlightESP") then
            local hl = Instance.new("Highlight")
            hl.Name = "HighlightESP"
            hl.FillTransparency = 0.75
            hl.OutlineColor = Color3.fromRGB(255, 30, 30)
            hl.OutlineTransparency = 0
            hl.FillColor = Color3.fromRGB(0, 0, 0)
            hl.Parent = plr.Character
        end
    end
end)

-- Hitbox
local rainbowHue = 0
RunService.RenderStepped:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local head = plr.Character:FindFirstChild("Head")
            
            if hrp and not originalSizes[hrp] then originalSizes[hrp] = hrp.Size end
            if head and not originalSizes[head] then originalSizes[head] = head.Size end

            if HitboxEnabled then
                rainbowHue = (rainbowHue + 0.03) % 1
                local color = RainbowHitbox and Color3.fromHSV(rainbowHue, 1, 1) or Color3.fromRGB(255, 60, 60)
                
                if hrp then
                    hrp.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                    hrp.Transparency = 0.22
                    hrp.Color = color
                    hrp.CanCollide = false
                    hrp.Material = Enum.Material.ForceField
                end
                if head then
                    head.Size = Vector3.new(HitboxSize*0.6, HitboxSize*0.6, HitboxSize*0.6)
                    head.Transparency = 0.22
                    head.Color = color
                    head.Material = Enum.Material.ForceField
                end
            else
                if hrp then hrp.Size = originalSizes[hrp] or Vector3.new(2,2,1); hrp.Transparency = 0 end
                if head then head.Size = originalSizes[head] or Vector3.new(1,1,1); head.Transparency = 0 end
            end
        end
    end
end)

-- TriggerBot Instant
RunService.RenderStepped:Connect(function()
    if not TriggerBotEnabled or not HitboxEnabled then return end
    if tick() - lastShot < TriggerCooldown then return end
    
    local target = GetClosestTarget()
    if target then
        local pos, onScreen = Camera:WorldToViewportPoint(target.Position)
        if onScreen then
            local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
            if distance < HitboxSize * 10 then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                task.wait(0.000008)
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                lastShot = tick()
            end
        end
    end
end)

