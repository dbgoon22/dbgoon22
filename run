-- =============================================
-- HACKED JAJAJAJA - Speed Hack + GUI Ajustable
-- Velocidad máxima: 10000
-- Abre con la tecla R
-- =============================================

local player = game:GetService("Players").LocalPlayer
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local speedValue = 100  -- Velocidad actual (empieza en 100)

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "HACKED_JAJAJA"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = player:WaitForChild("PlayerGui")

local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 320, 0, 250)
Frame.Position = UDim2.new(0.5, -160, 0.5, -125)
Frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
Frame.BorderSizePixel = 0
Frame.Visible = false
Frame.Parent = ScreenGui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 50)
Title.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
Title.Text = "HACKED JAJAJAJA"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextScaled = true
Title.Font = Enum.Font.GothamBold
Title.Parent = Frame

local SpeedLabel = Instance.new("TextLabel")
SpeedLabel.Size = UDim2.new(1, 0, 0, 40)
SpeedLabel.Position = UDim2.new(0, 0, 0, 50)
SpeedLabel.BackgroundTransparency = 1
SpeedLabel.Text = "Velocidad: " .. speedValue
SpeedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedLabel.TextScaled = true
SpeedLabel.Font = Enum.Font.Gotham
SpeedLabel.Parent = Frame

-- TextBox para ajustar velocidad
local SpeedBox = Instance.new("TextBox")
SpeedBox.Size = UDim2.new(0.7, 0, 0, 40)
SpeedBox.Position = UDim2.new(0.15, 0, 0, 100)
SpeedBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
SpeedBox.Text = tostring(speedValue)
SpeedBox.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedBox.TextScaled = true
SpeedBox.Font = Enum.Font.Gotham
SpeedBox.Parent = Frame

local ApplyButton = Instance.new("TextButton")
ApplyButton.Size = UDim2.new(0.8, 0, 0, 45)
ApplyButton.Position = UDim2.new(0.1, 0, 0, 160)
ApplyButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
ApplyButton.Text = "SPEED ON"
ApplyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ApplyButton.TextScaled = true
ApplyButton.Font = Enum.Font.GothamBold
ApplyButton.Parent = Frame

local speedEnabled = false
local connection = nil

local function setSpeed(speed)
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.WalkSpeed = math.clamp(speed, 16, 10000)
    end
end

-- Aplicar velocidad desde el TextBox
SpeedBox.FocusLost:Connect(function()
    local newSpeed = tonumber(SpeedBox.Text)
    if newSpeed then
        speedValue = math.clamp(newSpeed, 16, 10000)
        SpeedLabel.Text = "Velocidad: " .. speedValue
        SpeedBox.Text = tostring(speedValue)
        if speedEnabled then
            setSpeed(speedValue)
        end
    else
        SpeedBox.Text = tostring(speedValue)
    end
end)

ApplyButton.MouseButton1Click:Connect(function()
    speedEnabled = not speedEnabled
    if speedEnabled then
        ApplyButton.Text = "SPEED OFF"
        ApplyButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        connection = RunService.Heartbeat:Connect(function()
            setSpeed(speedValue)
        end)
    else
        ApplyButton.Text = "SPEED ON"
        ApplyButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        if connection then
            connection:Disconnect()
            connection = nil
        end
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = 16
        end
    end
end)

-- Abrir/Cerrar con R
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.R then
        Frame.Visible = not Frame.Visible
    end
end)

print("HACKED JAJAJAJA cargado | Presiona R | Velocidad máxima 10000")
