-- ESP Mejorado
local function UpdateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local box = ESPObjects[player]
                if not box then
                    box = Drawing.new("Square")
                    box.Thickness = 2.5
                    box.Filled = false
                    box.Transparency = 1
                    ESPObjects[player] = box
                end
                local top = Camera:WorldToViewportPoint(root.Position + Vector3.new(0,3,0))
                local bottom = Camera:WorldToViewportPoint(root.Position - Vector3.new(0,3,0))
                if top.Z > 0 then
                    box.Size = Vector2.new(2400 / (root.Position - Camera.CFrame.Position).Magnitude, bottom.Y - top.Y)
                    box.Position = Vector2.new(top.X - box.Size.X/2, top.Y)
                    box.Visible = true
                else
                    box.Visible = false
                end
            end
        end
    end
end

RunService.RenderStepped:Connect(UpdateESP)

-- Aimbot con potencia regulable
local function GetPrediction(target)
    local root = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    return root.Position + root.AssemblyLinearVelocity * 0.13
end

RunService.RenderStepped:Connect(function()
    if AimbotEnabled then
        local closest, dist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local pos = GetPrediction(plr)
                if pos then
                    local screen, onScreen = Camera:WorldToViewportPoint(pos)
                    if onScreen then
                        local d = (Vector2.new(screen.X, screen.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if d < dist then dist = d; closest = pos end
                    end
                end
            end
        end
        if closest then
            local current = Camera.CFrame
            local target = CFrame.lookAt(current.Position, closest)
            Camera.CFrame = current:Lerp(target, AimPower/250)
        end
    end
end)

-- Aim Assist
RunService.RenderStepped:Connect(function()
    if AimAssistEnabled and not AimbotEnabled then
        local closest, dist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local root = plr.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local screen, onScreen = Camera:WorldToViewportPoint(root.Position)
                    if onScreen then
                        local d = (Vector2.new(screen.X, screen.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if d < 200 and d < dist then
                            dist = d
                            closest = root.Position
                        end
                    end
                end
            end
        end
        if closest then
            local current = Camera.CFrame
            local target = CFrame.lookAt(current.Position, closest)
            Camera.CFrame = current:Lerp(target, 0.12)
        end
    end
end)

-- TriggerBot Mejorado
