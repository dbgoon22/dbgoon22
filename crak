-- Hitbox
local rainbowHue = 0
RunService.RenderStepped:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local head = plr.Character:FindFirstChild("Head")
            
            if hrp then SaveOriginalSize(hrp) end
            if head then SaveOriginalSize(head) end

            if HitboxEnabled then
                rainbowHue = (rainbowHue + 0.03) % 1
                local color = RainbowHitbox and Color3.fromHSV(rainbowHue, 1, 1) or Color3.fromRGB(255, 50, 50)
                
                if hrp then
                    hrp.Size = Vector3.new(8, 8, 8)
                    hrp.Transparency = 0.3
                    hrp.Color = color
                    hrp.CanCollide = false
                    hrp.Material = Enum.Material.ForceField
                end
                if head then
                    head.Size = Vector3.new(5.5, 5.5, 5.5)
                    head.Transparency = 0.3
                    head.Color = color
                    head.Material = Enum.Material.ForceField
                end
            else
                if hrp then RestoreOriginalSize(hrp) end
                if head then RestoreOriginalSize(head) end
            end
        end
    end
end)

