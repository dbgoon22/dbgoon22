-- VISIBILIDAD (bypass mejorado)
local function IsVisible(target)
    if not target then return false end
    local ray = Ray.new(Camera.CFrame.Position, (target.Position - Camera.CFrame.Position).Unit * 2000)
    local ignoreList = {LocalPlayer.Character, Workspace.CurrentCamera}
    local hit = Workspace:FindPartOnRayWithIgnoreList(ray, ignoreList)
    return hit == nil or hit == target
end

-- AIMBOT PERFECTO
RunService.RenderStepped:Connect(function()
    if not AimAssistEnabled then return end
    local closest, dist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head and IsVisible(head) then
                local pos, onScreen = Camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if d < dist then
                        dist = d
                        closest = head.Position
                    end
                end
            end
        end
    end
    if closest then
        local cf = Camera.CFrame
        Camera.CFrame = cf:Lerp(CFrame.lookAt(cf.Position, closest), AimPower/110)
    end
end)

